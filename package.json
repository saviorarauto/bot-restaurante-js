{
  "name": "bot-marmita",
  "version": "1.0.0",
  "description": "Bot de WhatsApp para gerenciamento de pedidos de marmita",
  "author": "Mineirinho",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "electron"
  ],
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.15.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "natural": "6.12.0",
    "qr-image": "^3.2.0",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
  "appId": "com.bot.marmita",
  "productName": "Bot Marmita",
  "asar": true,
  "compression": "maximum",
  "directories": {
    "output": "dist"
  },
  "files": [
    "**/*",
    "!dist/**/*",
    "!.git/**/*",
    "!.wwebjs_auth/**/*",
    "!.wwebjs_cache/**/*"
  ],
  "extraResources": [
    {
      "from": ".env",
      "to": ".env"
    }
  ],
  "asarUnpack": [
    "**/node_modules/puppeteer/**/*",
    "**/.wwebjs_auth/**/*",
    "**/.wwebjs_cache/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "portable",
        "arch": [
          "x64"
        ]
      }
    ]
  }
}
}
